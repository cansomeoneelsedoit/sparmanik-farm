  category       String?
  duration       String?
  type           VideoType
  url            String?
  path           String?
  thumbnailPath  String?   @map("thumbnail_path")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modules      Module[]

  @@index([organizationId])
  @@map("videos")
}

// ============================================================================
// Training — Boyd's in-app learning platform. A Course composes reusable
// MODULES (video / pictures / text, each with auto-marked Questions) through
// the CourseModule join — the same module can sit in many courses, and modules
// can exist standalone in the library. Passing a module unlocks the next in
// that course. Question payloads live in a JSON `config` so the four types
// (multiple choice, fill-the-blank, ordering, photo-spot) share one table;
// marking is SERVER-side only (the player never receives the correct answers
// — see src/server/training.ts).
//
// Naming note: the DB tables keep their original names (lessons /
// lesson_attempts / lesson_id) from before the modules refactor — only the
// Prisma models and the UI say "module".
// ============================================================================

enum QuestionType {
  MULTIPLE_CHOICE
  FILL_BLANK
  ORDER
  PHOTO_SPOT
}

model Course {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  titleEn        String   @map("title_en")
  titleId        String   @map("title_id")
  description    String?
  /** Staff only see published courses; drafts are builder-only. */
  published      Boolean  @default(false)
  /** Price in IDR. Null/0 = free. Priced courses need an enrollment (paid or
   *  granted) before the modules open; everyone can still SEE the course card. */
  priceIdr       Decimal? @db.Decimal(18, 4) @map("price_idr")
  /** Optional cover picture shown on the course card + hero (inline WebP, same
   *  pattern as Module.imageData). Absent → the generated gradient cover
   *  (src/lib/cover-art.ts) is used instead. */
  imageData      Bytes?   @map("image_data")
  imageMime      String?  @map("image_mime")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modules      CourseModule[]
  enrollments  CourseEnrollment[]

  @@index([organizationId])
  @@map("courses")
}

/** Access to a priced course: created when the learner pays (recorded manually
 *  for now — Boyd collects the money however suits) or when the owner grants
 *  free access. Free courses need no enrollment. */
model CourseEnrollment {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  courseId       String   @map("course_id")
  userId         String   @map("user_id")
  /** What was actually paid (IDR); null for granted/free enrollments. */
  paidAmount     Decimal? @db.Decimal(18, 4) @map("paid_amount")
  /** How it was paid — "cash" / "transfer" / "granted" etc. Free text. */
  paidVia        String?  @map("paid_via")
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("course_enrollments")
}

/** A module's place (and order) inside a course. Deleting a course removes its
 *  join rows but NOT the modules — they stay in the library for reuse. */
model CourseModule {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  courseId       String   @map("course_id")
  moduleId       String   @map("module_id")
  /** Order within the course; module N+1 unlocks when N is passed. */
  rank           Int
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module       Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([courseId, moduleId])
  @@index([organizationId])
  @@index([courseId, rank])
  @@map("course_modules")
}

model Module {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  titleEn        String   @map("title_en")
  titleId        String   @map("title_id")
  /** Optional teaching video — reuses the Videos library (TikTok/IG/upload). */
  videoId        String?  @map("video_id")
  /** Optional teaching text (plain text/markdown-lite), per language. */
  bodyEn         String?  @map("body_en")
  bodyId         String?  @map("body_id")
  /** Optional teaching picture, stored inline (same pattern as Item.photoData). */
  imageData      Bytes?   @map("image_data")
  imageMime      String?  @map("image_mime")
  /** SCORM 1.2 package: directory under uploads/scorm/<id>/ holding the
   *  extracted zip, plus the launch href from imsmanifest.xml
   *  ("<dir>|<launchHref>"). Played in an iframe with a window.API shim that
   *  reports completion/score into ModuleAttempt. Null = not a SCORM module. */
  scormPath      String?  @map("scorm_path")
  /** Minimum score (%) to pass and unlock the next module. */
  passPct        Int      @default(80) @map("pass_pct")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  video        Video?        @relation(fields: [videoId], references: [id], onDelete: SetNull)
  courses      CourseModule[]
  questions    Question[]
  attempts     ModuleAttempt[]

  @@index([organizationId])
  @@map("lessons")
}

model Question {
  id             String       @id @default(cuid())
  organizationId String?      @map("organization_id")
  moduleId       String       @map("lesson_id")
  rank           Int
  type           QuestionType
  promptEn       String       @map("prompt_en")
  promptId       String       @map("prompt_id")
  /** Optional picture the question refers to (photo-spot uses this). */
  imageData      Bytes?       @map("image_data")
  imageMime      String?      @map("image_mime")
  /** Type-specific payload INCLUDING the correct answers — server-only:
   *  MULTIPLE_CHOICE / PHOTO_SPOT: { options: {en,id}[], correct: number[] }
   *  FILL_BLANK:                   { accept: string[] }  (any language)
   *  ORDER:                        { items: {en,id}[] }  (config order = correct) */
  config         Json
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module       Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([moduleId, rank])
  @@map("questions")
}

model ModuleAttempt {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  moduleId       String   @map("lesson_id")
  userId         String   @map("user_id")
  /** 0–100, marked server-side. */
  score          Int
  passed         Boolean
  /** The submitted answers, for review/audit. */
  answers        Json
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module       Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([moduleId, userId])
  @@index([userId])
  @@map("lesson_attempts")
}

// Ranked LLM credentials. The ai-chain at src/server/ai-chain.ts walks
// these top-to-bottom (lowest rank first), advances on 429/quota/4xx,
// retries network/5xx once. Multiple free Gemini accounts + paid
// Anthropic backstop is the typical pattern.
model AiProviderKey {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  /** "gemini" | "groq" | "cerebras" | "openrouter" | "mistral" | "anthropic" */
  provider       String
  /** Human label e.g. "Primary", "Boyd backup". Surfaced in the settings UI. */
  label          String?
  /** Real secret. Never sent to the client; settings UI shows last 6 chars only. */
  apiKey         String    @map("api_key")
  /** Override the provider's default model for this key. Null = use default. */
  model          String?
  /** Lower = tried first. */
  rank           Int       @default(100)
  enabled        Boolean   @default(true)
  /** "ok" | "quota" | "error" | "untested" — written after each call/test. */
  lastStatus     String?   @map("last_status")
  lastUsedAt     DateTime? @map("last_used_at")
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([rank])
  @@map("ai_provider_keys")
}

// Editable pick-list shown in the "Log labour" dialog. Staff are forced to
// pick one of these (or "Other" → manual entry). Each row is scoped to one
// org; admins can rename/disable/add via /settings/labour-tasks.
model LabourTask {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  name           String
  sortOrder      Int      @default(0) @map("sort_order")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("labour_tasks")
}

// ---------- Settings ----------

model Setting {
  id            String  @id @default("singleton") // single-row table
  farmName      String  @default("Sparmanik Farm") @map("farm_name")
  exchangeRate  Decimal @db.Decimal(12, 4) @default(10200) @map("exchange_rate")
  defaultLocale String  @default("en") @map("default_locale")

  @@map("settings")
}

model ExchangeRateHistory {
  id            String   @id @default(cuid())
  rate          Decimal  @db.Decimal(12, 4)
  effectiveFrom DateTime @map("effective_from")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([effectiveFrom])
  @@map("exchange_rate_history")
}

// ---------- Audit ----------

model AuditAction {
  id             String    @id @default(cuid())
  organizationId String?    @map("organization_id")
  type           String
  entityType     String    @map("entity_type")
  entityId       String    @map("entity_id")
  userId         String?   @map("user_id")
  description    String
  payload        Json
  undone         Boolean   @default(false)
  undoneAt       DateTime? @map("undone_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
  @@index([undone, createdAt])
  @@map("audit_actions")
}

