generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Auth.js (NextAuth v5) Prisma adapter models
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  // Authorisation tier. SUPERUSER can manage other users (create / edit /
  // reset password / delete) via /admin/users. USER is the default.
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts        Account[]
  sessions        Session[]
  aiMessages      AiMessage[]
  aiConversations AiConversation[]
  auditActions    AuditAction[]
  staff           Staff?
  memberships     OrganizationMembership[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// Sparmanik Farm domain
// ============================================================================

enum HarvestStatus {
  LIVE
  CLOSED
}

// Payment lifecycle for a POS sale. Record-only / cash sales are born PAID.
// Live QRIS/Square sales (Phase 2/3) are born PENDING and a webhook flips them
// to PAID/FAILED/EXPIRED — reporting only counts PAID so pending/abandoned QRs
// never inflate revenue.
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum PaymentMethod {
  CASH
  QRIS
  CARD
  TRANSFER
}

enum SaleGrade {
  A
  B
  C
  D
}

// Non-sale fates of harvested produce. Tracked so total yield reconciles:
// total grown = sold + breakage + staff consumption + giveaways. No cash impact.
enum DispositionType {
  BREAKAGE // cracked / broken / spillage
  STAFF    // eaten or taken by staff
  GIVEAWAY // free samples / giveaways
}

enum CustomerType {
  RETAILER
  WHOLESALER
  CONSUMER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum SopStatus {
  ACTIVE
  ARCHIVED
}

enum VideoType {
  YOUTUBE
  UPLOAD
}

enum CommentRole {
  ADMIN
  STAFF
}

enum AiRole {
  USER
  ASSISTANT
}

enum UserRole {
  USER
  SUPERUSER
}

enum OrgRole {
  OWNER
  MEMBER
}

// ---------- Multi-organisation ----------

// One row per company/farm. Every tenant-scoped table carries an
// `organizationId` FK back to this. Users belong to one or more orgs via
// OrganizationMembership; the active org is tracked via a cookie and
// auto-applied by the Prisma client extension in src/lib/prisma.ts.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  memberships     OrganizationMembership[]
  categories      Category[]
  produces        Produce[]
  greenhouses    Greenhouse[]
  suppliers       Supplier[]
  customers       Customer[]
  items           Item[]
  batches         Batch[]
  staff           Staff[]
  harvests        Harvest[]
  harvestUsages   HarvestUsage[]
  harvestAssets   HarvestAsset[]
  sales           Sale[]
  dispositions    HarvestDisposition[]
  tasks           Task[]
  nutrientRecipes NutrientRecipe[]
  sops            Sop[]
  videos          Video[]
  auditActions    AuditAction[]
  aiConversations AiConversation[]
  aiMessages      AiMessage[]
  expenses        Expense[]
  labourTasks     LabourTask[]
  aiProviderKeys  AiProviderKey[]
  stockSales      StockSale[]
  posPayments     PosPayment[]
  paymentGatewayCredentials PaymentGatewayCredential[]

  @@map("organizations")
}

model Expense {
  id              String   @id @default(cuid())
  organizationId  String?  @map("organization_id")
  date            DateTime @db.Date
  amount          Decimal  @db.Decimal(18, 4)
  category        String?
  /** Free-form name of who got paid — contractor, individual, utility co. */
  payee           String
  description     String?
  /** Optional: allocate this expense to a specific harvest's P&L. When
   * null, the expense stays at the business level (general overhead). */
  harvestId       String?  @map("harvest_id")
  /** "cash", "transfer", "card", etc. — free-form. */
  paymentMethod   String?  @map("payment_method")
  /** Optional receipt photo (uploads-relative path). */
  receiptPath     String?  @map("receipt_path")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  harvest      Harvest?      @relation(fields: [harvestId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([harvestId])
  @@index([date])
  @@map("expenses")
}

model OrganizationMembership {
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           OrgRole  @default(MEMBER)
  joinedAt       DateTime @default(now()) @map("joined_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@index([organizationId])
  @@map("organization_memberships")
}

// ---------- Lookup tables ----------

model Category {
  id             String       @id @default(cuid())
  organizationId String?       @map("organization_id")
  name           String
  items          Item[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("categories")
}

model Produce {
  id             String           @id @default(cuid())
  organizationId String?           @map("organization_id")
  name           String
  // Barcode global-unique stays — a physical barcode is unique to a product
  // worldwide; if two orgs happen to scan the same barcode that's the same
  // produce, so we keep one row globally.
  barcode        String?          @unique
  harvests       Harvest[]
  sales          Sale[]
  dispositions   HarvestDisposition[]
  inCrops        HarvestProduce[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("produce")
}

// Join table for multi-produce harvests. The legacy `Harvest.produceId` is
// kept as the "primary" produce (first one selected at creation) for
// backward compat with reports, but the canonical list lives here.
model HarvestProduce {
  harvestId String   @map("harvest_id")
  produceId String   @map("produce_id")
  createdAt DateTime @default(now()) @map("created_at")

  harvest Harvest @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  produce Produce @relation(fields: [produceId], references: [id])

  @@id([harvestId, produceId])
  @@index([produceId])
  @@map("harvest_produces")
}

model Greenhouse {
  id             String           @id @default(cuid())
  organizationId String?           @map("organization_id")
  name           String
  location       String?
  type           String?
  notes          String?
  harvests       Harvest[]
  wageEntries    WageEntryLine[]

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("greenhouses")
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String?   @map("organization_id")
  name           String
  phone          String?
  email          String?
  notes          String?
  shopUrl        String?  @map("shop_url")
  items          Item[]
  batches        Batch[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // A double-tap / re-typed name must not split a supplier's purchase history
  // across duplicate rows (app review #38). App code find-or-creates
  // case-insensitively; this constraint is the backstop.
  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("suppliers")
}

/// Who we SELL to. Mirrors Supplier (who we buy from). Type drives reporting
/// later (resale vs distribution vs end consumer). Created ad-hoc from the
/// Log-sale dialog (search-first, create if missing).
model Customer {
  id             String       @id @default(cuid())
  organizationId String?      @map("organization_id")
  name           String
  type           CustomerType @default(CONSUMER)
  phone          String?
  email          String?
  notes          String?
  /** Brand logo stored INLINE on the row (same pattern as Item.photoData) so
   *  it travels with the customer during sync / backup / restore. Small WebP
   *  written by the customer edit dialog. */
  logoData       Bytes?       @map("logo_data")
  logoMime       String?      @map("logo_mime")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales        Sale[]
  dispositions HarvestDisposition[]

  // See Supplier: prevents duplicate customers splitting sales history (#38).
  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("customers")
}

// ---------- Inventory ----------

model Item {
  id                String   @id @default(cuid())
  organizationId    String?   @map("organization_id")
  /** Internal short code printed on bins and used in search ("SF00001"). */
  code              String
  name              String
  description       String?
  photoPath         String?  @map("photo_path")
  /** Photo bytes stored INLINE on the row. Travel with the item during
   * sync / backup / restore so we never desync between the filesystem
   * and the row pointer. `photo_path` stays as a legacy field for items
   * that haven't been migrated yet (the backfill script + the
   * `/api/uploads/[...path]` route still serve those off disk). */
  photoData         Bytes?   @map("photo_data")
  photoMime         String?  @map("photo_mime")
  photoWidth        Int?     @map("photo_width")
  photoHeight       Int?     @map("photo_height")
  categoryId        String?  @map("category_id")
  unit              String
  subUnit           String?  @map("sub_unit")
  subFactor         Decimal? @db.Decimal(18, 4) @map("sub_factor")
  /** Free-text tag that groups items of the same underlying substance
   * across separate SKUs / pack sizes / suppliers. Pair with subUnit
   * + subFactor so a 25 kg bag and a 1 kg bag can both belong to
   * family "Meroke Calnit" and roll up to a total kilogram figure. */
  productFamily     String?  @map("product_family")
  location          String?
  reusable          Boolean  @default(false)
  reorder           Decimal  @default(0) @db.Decimal(18, 4)
  shopeeUrl         String?  @map("shopee_url")
  defaultSupplierId String?  @map("default_supplier_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization     Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category         Category?       @relation(fields: [categoryId], references: [id])
  defaultSupplier  Supplier?       @relation(fields: [defaultSupplierId], references: [id])
  batches          Batch[]
  harvestAssets    HarvestAsset[]
  harvestUsages    HarvestUsage[]
  stockSales       StockSale[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([categoryId])
  @@index([defaultSupplierId])
  @@index([organizationId, productFamily])
  @@map("items")
}

model Batch {
  id                    String   @id @default(cuid())
  organizationId        String?   @map("organization_id")
  itemId                String   @map("item_id")
  supplierId            String?  @map("supplier_id")
  date                  DateTime @db.Date
  qty                   Decimal  @db.Decimal(18, 4)
  price                 Decimal  @db.Decimal(18, 4)
  exchangeRate          Decimal  @db.Decimal(12, 4) @map("exchange_rate")
  // --- Depreciation fields (cocopeat / rockwool / grow bags etc) ---
  // maxUses = 1 means the batch is NOT depreciable (existing behaviour).
  // maxUses > 1 means each harvest gets charged amortisedCostPerUse * qty,
  // and useCount increments per install. See docs in `src/server/fifo.ts`.
  maxUses               Int      @default(1) @map("max_uses")
  useCount              Int      @default(0) @map("use_count")
  amortisedCostPerUse   Decimal? @db.Decimal(18, 4) @map("amortised_cost_per_use")
  // Returned batches were created at end-harvest with price=0 because the
  // original purchase cost is already on Business P&L. The amortised charge
  // still follows the batch via amortisedCostPerUse.
  returned              Boolean  @default(false)
  // Set when a reusable batch was checked back in as damaged or lost from
  // a specific harvest, so the Financials page can attribute the loss.
  // Null in all normal cases.
  damagedFromHarvestId  String?  @map("damaged_from_harvest_id")
  createdAt             DateTime @default(now()) @map("created_at")

  organization      Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item              Item               @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplier          Supplier?          @relation(fields: [supplierId], references: [id])
  consumptions      BatchConsumption[]
  damagedFromHarvest Harvest?          @relation("BatchDamagedFromHarvest", fields: [damagedFromHarvestId], references: [id])

  @@index([organizationId])
  @@index([itemId, date])
  @@map("batches")
}

// Source of truth for FIFO consumption. remaining(batch) = batch.qty - SUM(consumptions.qty).
model BatchConsumption {
  id              String   @id @default(cuid())
  batchId         String   @map("batch_id")
  qty             Decimal  @db.Decimal(18, 4)
  unitCost        Decimal  @db.Decimal(18, 4) @map("unit_cost")
  harvestAssetId  String?  @map("harvest_asset_id")
  harvestUsageId  String?  @map("harvest_usage_id")
  stockSaleId     String?  @map("stock_sale_id")
  consumedAt      DateTime @default(now()) @map("consumed_at")

  batch         Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  harvestAsset  HarvestAsset? @relation(fields: [harvestAssetId], references: [id], onDelete: Cascade)
  harvestUsage  HarvestUsage? @relation(fields: [harvestUsageId], references: [id], onDelete: Cascade)
  stockSale     StockSale?    @relation(fields: [stockSaleId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([harvestAssetId])
  @@index([harvestUsageId])
  @@index([stockSaleId])
  @@map("batch_consumptions")
}

// ---------- Off-harvest stock sales ----------
// Selling inventory directly to a buyer (e.g. 10 m of drip pipe to a
// neighbour) — not produce from a greenhouse cycle. Consumes stock via the
// same FIFO ledger as installs/usages, with a cost snapshot so Financials
// can show profit = amount − cogs without re-deriving.
model StockSale {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  itemId         String   @map("item_id")
  date           DateTime @db.Date
  /** Quantity sold, in PACK units (the canonical Batch unit). */
  qty            Decimal  @db.Decimal(18, 4)
  /** What the buyer paid, total IDR. */
  amount         Decimal  @db.Decimal(18, 4)
  /** FIFO cost of the sold qty, snapshotted at sale time. */
  cogs           Decimal  @db.Decimal(18, 4)
  /** Free-text buyer name — "Pak Budi". Optional by design; upgrade to a
   * Buyer entity later if reselling becomes a real side business. */
  buyer          String?
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item               @relation(fields: [itemId], references: [id], onDelete: Cascade)
  consumptions BatchConsumption[]

  @@index([organizationId])
  @@index([itemId, date])
  @@map("stock_sales")
}

// ---------- Harvests ----------

model Harvest {
  id             String        @id @default(cuid())
  organizationId String?        @map("organization_id")
  greenhouseId   String        @map("greenhouse_id")
  produceId      String?       @map("produce_id")
  name           String
  variety        String?
  startDate      DateTime      @db.Date @map("start_date")
  endDate        DateTime?     @db.Date @map("end_date")
  status         HarvestStatus @default(LIVE)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization     Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  greenhouse       Greenhouse        @relation(fields: [greenhouseId], references: [id])
  produce          Produce?          @relation(fields: [produceId], references: [id])
  produces         HarvestProduce[]
  assets           HarvestAsset[]
  usages           HarvestUsage[]
  sales            Sale[]
  dispositions     HarvestDisposition[]
  wageLines        WageEntryLine[]
  tasks            Task[]
  damagedBatches   Batch[]           @relation("BatchDamagedFromHarvest")
  expenses         Expense[]

  @@index([organizationId])
  @@index([status, startDate])
  @@map("harvests")
}

model HarvestAsset {
  id              String   @id @default(cuid())
  organizationId  String?   @map("organization_id")
  harvestId       String   @map("harvest_id")
  itemId          String   @map("item_id")
  qty             Decimal  @db.Decimal(18, 4)
  date            DateTime @db.Date
  reusable        Boolean  @default(false)
  condition       String?
  depreciable     Boolean  @default(false)
  amortisedCharge Decimal? @db.Decimal(18, 4) @map("amortised_charge")
  maxUses         Int      @default(1) @map("max_uses")
  useCount        Int      @default(0) @map("use_count")
  discarded       Boolean  @default(false)
  // Check-in state when the asset comes back to inventory mid-harvest or at
  // end-harvest. "good" returns to inventory; "damaged"/"lost" stay with the
  // business and the residual depreciable value gets written off on the
  // Financials page (and linked back to this harvest).
  returnCondition String?  @map("return_condition")
  returnedAt      DateTime? @map("returned_at")
  returnNote      String?  @map("return_note")
  createdAt       DateTime @default(now()) @map("created_at")

  organization Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  harvest      Harvest            @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  item         Item               @relation(fields: [itemId], references: [id])
  consumptions BatchConsumption[]

  @@index([organizationId])
  @@index([harvestId])
  @@map("harvest_assets")
}

model HarvestUsage {
  id             String   @id @default(cuid())
  organizationId String?   @map("organization_id")
  harvestId      String   @map("harvest_id")
  itemId         String   @map("item_id")
  qty            Decimal  @db.Decimal(18, 4)
  displayQty     String?  @map("display_qty")
  date           DateTime @db.Date
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  harvest      Harvest            @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  item         Item               @relation(fields: [itemId], references: [id])
  consumptions BatchConsumption[]

  @@index([organizationId])
  @@index([harvestId])
  @@map("harvest_usages")
}

model Sale {
  id             String    @id @default(cuid())
  organizationId String?    @map("organization_id")
  harvestId      String    @map("harvest_id")
  produceId      String    @map("produce_id")
  date           DateTime  @db.Date
  grade          SaleGrade
  weight         Decimal   @db.Decimal(18, 4)
  pricePerKg     Decimal   @db.Decimal(18, 4) @map("price_per_kg")
  amount         Decimal   @db.Decimal(18, 4)
  /// The on-top packaging charge INCLUDED in `amount` (0 when none). Stored
  /// separately so discount maths can exclude it — without this, a boxed sale
  /// looked like a markup and cancelled real discounts in the stats (review #15).
  /// Historical rows stay 0 (the component wasn't recorded separately).
  packagingCharge Decimal  @default(0) @db.Decimal(18, 4) @map("packaging_charge")
  customerId     String?   @map("customer_id")
  /// Payment lifecycle. Existing/cash sales are PAID; a live QRIS/Square sale is
  /// born PENDING and flipped by a webhook (Phase 2/3). Reporting sums PAID only.
  paymentStatus  PaymentStatus @default(PAID) @map("payment_status")
  /// The POS basket this sale line was paid under (many lines → one payment).
  /// Non-unique FK: a multi-grade cart is one payment across several Sale rows.
  paymentId      String?   @map("payment_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  harvest      Harvest      @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  produce      Produce      @relation(fields: [produceId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  payment      PosPayment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([harvestId, date])
  @@index([customerId])
  @@index([paymentId])
  @@map("sales")
}

// A POS checkout: ONE payment covering a basket that may be several Sale lines
// (e.g. 50kg Grade A + 20kg Grade B, paid once). `Sale.paymentId` points here.
// `provider` = record-only (Phase 1, no live charge) | xendit (QRIS) | square.
// Live charges are created PENDING and confirmed by a webhook (Phase 2/3);
// grossAmount = Σ line amounts, feeAmount/netAmount reconcile against the
// gateway payout. `externalId` is the gateway charge id and the webhook
// idempotency anchor.
model PosPayment {
  id             String        @id @default(cuid())
  organizationId String?       @map("organization_id")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  provider       String        @default("record-only")
  currency       String        @default("IDR")
  grossAmount    Decimal       @db.Decimal(18, 4) @map("gross_amount")
  feeAmount      Decimal       @default(0) @db.Decimal(18, 4) @map("fee_amount")
  netAmount      Decimal?      @db.Decimal(18, 4) @map("net_amount")
  /// Cash: amount handed over and change given back (for the receipt).
  tendered       Decimal?      @db.Decimal(18, 4)
  changeDue      Decimal?      @db.Decimal(18, 4) @map("change_due")
  /// Free-text reference for "other method" (e.g. a bank ref the staff typed).
  note           String?
  externalId     String?       @map("external_id")
  checkoutUrl    String?       @map("checkout_url")
  qrString       String?       @map("qr_string")
  expiresAt      DateTime?     @map("expires_at")
  paidAt         DateTime?     @map("paid_at")
  rawEvent       Json?         @map("raw_event")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales        Sale[]

  @@unique([provider, externalId])
  @@index([organizationId])
  @@index([status])
  @@map("pos_payments")
}

// Per-org payment-gateway credentials (Phase 2/3). Mirrors AiProviderKey: the
// secret is never sent to the client (masked in the settings UI). `merchantRef`
// (Square location / Xendit business id) lets a session-less webhook resolve the
// org. The table is created in Phase 1 so the model exists; rows arrive in P2/3.
model PaymentGatewayCredential {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  provider       String
  currency       String
  label          String?
  apiKey         String    @map("api_key")
  webhookSecret  String?   @map("webhook_secret")
  merchantRef    String?   @map("merchant_ref")
  enabled        Boolean   @default(true)
  lastStatus     String?   @map("last_status")
  lastUsedAt     DateTime? @map("last_used_at")
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([provider, merchantRef])
  @@index([organizationId])
  @@map("payment_gateway_credentials")
}

// Non-sale disposition of harvested produce (breakage, staff consumption,
// giveaways/samples). Mirrors the shape of Sale/HarvestUsage but carries NO
// cash — `pricePerKg` is an optional memo value only and never enters the P&L.
// Exists so total yield can be reconciled: harvested = sold + these.
model HarvestDisposition {
  id             String          @id @default(cuid())
  organizationId String?         @map("organization_id")
  harvestId      String          @map("harvest_id")
  produceId      String          @map("produce_id")
  type           DispositionType
  weight         Decimal         @db.Decimal(18, 4)
  /** Optional memo value at list price (Rp/kg). Display only — never summed
   *  into revenue or net profit. */
  pricePerKg     Decimal?        @db.Decimal(18, 4) @map("price_per_kg")
  /** Optional: which staff member consumed it (STAFF type). */
  staffId        String?         @map("staff_id")
  /** Optional: who received the sample (GIVEAWAY type). */
  customerId     String?         @map("customer_id")
  note           String?
  date           DateTime        @db.Date
  createdAt      DateTime        @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  harvest      Harvest       @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  produce      Produce       @relation(fields: [produceId], references: [id])
  staff        Staff?        @relation(fields: [staffId], references: [id], onDelete: SetNull)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([harvestId, date])
  @@map("harvest_dispositions")
}

// ---------- Staff & Wages ----------

model Staff {
  id             String   @id @default(cuid())
  organizationId String?   @map("organization_id")
  name           String
  role           String?
  avatar         String?
  photoPath      String?  @map("photo_path")
  /** Free-form bio / fun facts (family, pets, hobbies, animals' names). */
  bio            String?
  userId         String?  @unique @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  rates        StaffRate[]
  wageEntries  WageEntry[]
  tasks        Task[]       @relation("AssignedTasks")
  dispositions HarvestDisposition[]

  @@index([organizationId])
  @@map("staff")
}

model StaffRate {
  id            String   @id @default(cuid())
  staffId       String   @map("staff_id")
  rate          Decimal  @db.Decimal(18, 4)
  effectiveFrom DateTime @db.Date @map("effective_from")
  createdAt     DateTime @default(now()) @map("created_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, effectiveFrom])
  @@map("staff_rates")
}

model WageEntry {
  id         String   @id @default(cuid())
  staffId    String   @map("staff_id")
  date       DateTime @db.Date
  totalHours Decimal  @db.Decimal(8, 2) @map("total_hours")
  createdAt  DateTime @default(now()) @map("created_at")

  staff Staff           @relation(fields: [staffId], references: [id], onDelete: Cascade)
  lines WageEntryLine[]

  @@index([staffId, date])
  @@map("wage_entries")
}

model WageEntryLine {
  id           String  @id @default(cuid())
  wageEntryId  String  @map("wage_entry_id")
  harvestId    String? @map("harvest_id")
  greenhouseId String? @map("greenhouse_id")
  hours        Decimal @db.Decimal(8, 2)
  task         String?

  wageEntry  WageEntry   @relation(fields: [wageEntryId], references: [id], onDelete: Cascade)
  harvest    Harvest?    @relation(fields: [harvestId], references: [id])
  greenhouse Greenhouse? @relation(fields: [greenhouseId], references: [id])

  @@index([wageEntryId])
  @@index([harvestId])
