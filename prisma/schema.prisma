// ---------- Plant tags (QR stakes) ----------

/// A physical QR stake. It belongs to ONE greenhouse for life and is recycled
/// there: each crop it's staked with gets a PlantRecord; reallocating ends the
/// current record and starts the next, so the tag keeps its full history.
/// The QR encodes /t/<code>.
model PlantTag {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  greenhouseId   String   @map("greenhouse_id")
  /// Short unguessable slug in the QR URL — stable for the stake's whole life.
  code           String   @unique
  /// Human label printed under the QR, e.g. "A01A" (row A, bag 01, plant A).
  label          String
  /// Greenhouse-layout position (nullable — ad-hoc tags have no grid slot):
  /// row A–J (south→north), col 1–48 (east→west), plantSlot "A"/"B" (2 per bag).
  row            String?  @map("row")
  col            Int?     @map("col")
  plantSlot      String?  @map("plant_slot")
  /// Intended/layout variety for this position (what the row is planted with).
  /// Drives the map colour + the default when a plant is assigned.
  produceId      String?  @map("produce_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  greenhouse   Greenhouse    @relation(fields: [greenhouseId], references: [id], onDelete: Cascade)
  produce      Produce?      @relation(fields: [produceId], references: [id], onDelete: SetNull)
  records      PlantRecord[]

  @@unique([greenhouseId, label])
  @@index([organizationId])
  @@index([greenhouseId, row, col, plantSlot])
  @@map("plant_tags")
}

/// One crop's stay on a tag: what's planted, when, seed/method/notes. The
/// current record has endedAt = null; reallocation ends it and creates the
/// next, so scanning always shows the live plant plus its predecessors.
model PlantRecord {
  id        String    @id @default(cuid())
  tagId     String    @map("tag_id")
  harvestId String?   @map("harvest_id")
  produceId String?   @map("produce_id")
  plantedAt DateTime  @db.Date @map("planted_at")
  seed      String?
  method    String?
  notes     String?
  /// Optional plant photo, stored INLINE on the row (same pattern as
  /// Item.photoData) so it travels with the record through local→prod sync
  /// instead of living on the filesystem. Served via /api/plant-records/[id]/photo.
  photoData Bytes?    @map("photo_data")
  photoMime String?   @map("photo_mime")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")

  tag     PlantTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  harvest Harvest? @relation(fields: [harvestId], references: [id], onDelete: SetNull)
  produce Produce? @relation(fields: [produceId], references: [id], onDelete: SetNull)

  @@index([tagId, endedAt])
  @@map("plant_records")
}
