// Ranked LLM credentials. The ai-chain at src/server/ai-chain.ts walks
// these top-to-bottom (lowest rank first), advances on 429/quota/4xx,
// retries network/5xx once. Multiple free Gemini accounts + paid
// Anthropic backstop is the typical pattern.
model AiProviderKey {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  /** "gemini" | "groq" | "cerebras" | "openrouter" | "mistral" | "anthropic" */
  provider       String
  /** Human label e.g. "Primary", "Boyd backup". Surfaced in the settings UI. */
  label          String?
  /** Real secret. Never sent to the client; settings UI shows last 6 chars only. */
  apiKey         String    @map("api_key")
  /** Override the provider's default model for this key. Null = use default. */
  model          String?
  /** Lower = tried first. */
  rank           Int       @default(100)
  enabled        Boolean   @default(true)
  /** "ok" | "quota" | "error" | "untested" — written after each call/test. */
  lastStatus     String?   @map("last_status")
  lastUsedAt     DateTime? @map("last_used_at")
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([rank])
  @@map("ai_provider_keys")
}

// Editable pick-list shown in the "Log labour" dialog. Staff are forced to
// pick one of these (or "Other" → manual entry). Each row is scoped to one
// org; admins can rename/disable/add via /settings/labour-tasks.
model LabourTask {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  name           String
  sortOrder      Int      @default(0) @map("sort_order")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("labour_tasks")
}

