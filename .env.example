# --- Database ---
# Local dev (docker-compose runs Postgres on 5432; the web service inside compose
# uses host `db`, while running `npm run dev` on the host uses `localhost`).
DATABASE_URL="postgresql://sparmanik:sparmanik@localhost:5432/sparmanik?schema=public"

# On Railway, set DATABASE_URL to the Postgres plugin's connection string.
# Railway Postgres requires SSL; the pg client/Prisma handles this automatically
# when ?sslmode=require is appended. Set DATABASE_SSL=false to disable locally.
DATABASE_SSL=false

# --- API auth (legacy bearer token used by the farm-state endpoint) ---
# Leave unset to disable token enforcement.
FARM_API_TOKEN=

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-prod"
# The canonical app URL. In dev, http://localhost:3000.
AUTH_URL="http://localhost:3000"

# --- Anthropic (Claude) — required for Ask AI ---
ANTHROPIC_API_KEY=

# --- Google OAuth — required for Google Calendar sync ---
# 1. Create a Google Cloud project, enable Calendar API
# 2. Set up OAuth consent screen (External + your email as test user)
# 3. Create OAuth client ID for Web application
# 4. Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- File uploads ---
# Path the web container writes uploads to. In dev: ./uploads (default).
# In prod on Railway: mount a Volume at /data and set UPLOAD_DIR=/data/uploads.
UPLOAD_DIR=

# --- Misc ---
NODE_ENV=development
