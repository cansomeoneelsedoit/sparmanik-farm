# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.*
!.env.example

# uploaded media (dev: ./uploads; prod: Railway Volume)
/uploads/*
!/uploads/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code session state — not source code
.claude/

# Understand Anything indexing artefacts
.understand-anything/

# Local-only data-sync artifacts — never commit these. Backup .sql files
# include prod data and pg_dump's connection-string-derived strings.
prod-backup-*.sql
tmp-sync/


# Local pre-merge data backup (contains data; never commit)
local-premerge-backup.sql
*-premerge-backup.sql
